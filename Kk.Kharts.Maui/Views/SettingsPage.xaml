<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Kk.Kharts.Maui.ViewModels"
             x:Class="Kk.Kharts.Maui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
           
             Background="{StaticResource DashboardBackgroundBrush}">

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="20,24,20,40">

            <!-- Hero Card -->
            <Border Background="{StaticResource HeroCardBrush}"
                    StrokeShape="RoundRectangle 40"
                    StrokeThickness="0"
                    Padding="24"
                    Shadow="Medium">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18" VerticalOptions="Center">
                    <Border WidthRequest="78"
                            HeightRequest="78"
                            Background="{StaticResource HeroIconBrush}"
                            StrokeShape="RoundRectangle 30"
                            Padding="0">
                        <Label Text="👤"
                               FontSize="34"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               TextColor="White" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding CurrentUser.Email}"
                               FontSize="20"
                               FontFamily="PoppinsSemiBold"
                               TextColor="White" />
                        <Label Text="{Binding CurrentUser.Role}"
                               FontSize="14"
                               TextColor="#E8FFF6"
                               Opacity="0.9" />
                        <Label Text="KropKontrol • Plateforme IoT agricole"
                               FontSize="12"
                               TextColor="#F0FFFA"
                               Opacity="0.85" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Application Section -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Application"
                       Style="{StaticResource SectionTitle}" />

                <Border Style="{StaticResource CardView}" Padding="0">
                    <VerticalStackLayout>
                        <Grid Padding="16" ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="📱" FontSize="20" VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="16,0,0,0">
                                <Label Text="Version" Style="{StaticResource CardTitle}" />
                                <Label Text="Dernière mise à jour" Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="{Binding AppVersion}" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource SurfaceLight}" />

                        <Grid Padding="16" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenSupportCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.RowSpan="2" Text="📧" FontSize="20" VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                            <Label Grid.Column="1" Text="Support" Style="{StaticResource CardTitle}" />
                            <Label Grid.Column="1" Grid.Row="1" Text="info@kropkontrol.com" Style="{StaticResource CardSubtitle}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource SurfaceLight}" />

                        <Grid Padding="16" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenWebsiteCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.RowSpan="2" Text="🌐" FontSize="20" VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                            <Label Grid.Column="1" Text="Site Web" Style="{StaticResource CardTitle}" />
                            <Label Grid.Column="1" Grid.Row="1" Text="kropkontrol.com" Style="{StaticResource CardSubtitle}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Logout Button -->
            <Border BackgroundColor="#FFEDEDED" StrokeShape="RoundRectangle 16" Padding="8">
                <Button Text="Se déconnecter"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource PrimaryButton}"
                        BackgroundColor="{StaticResource Error}"
                        CornerRadius="14"
                        HeightRequest="54" />
            </Border>

            <!-- Footer -->
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,16,0,0">
                <Label FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="KropKontrol par " />
                            <Span Text="3ctec" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                            <Span Text=" &amp; " />
                            <Span Text="StratBerries" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label Text=" 2025" FontSize="11" TextColor="{StaticResource TextDisabled}" HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
