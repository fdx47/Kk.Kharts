<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Kk.Kharts.Maui.ViewModels"
             x:Class="Kk.Kharts.Maui.Views.DeviceDetailPage"
             x:DataType="vm:DeviceDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding GoBackCommand}" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*">
        <!-- Header Background -->
        <BoxView Grid.Row="0" HeightRequest="140" VerticalOptions="Start">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView Grid.RowSpan="2">
            <VerticalStackLayout Spacing="20" Padding="16,12,16,24">
                
                <!-- Device Header Card -->
                <Border Style="{StaticResource CardView}" Padding="16" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" 
                               BackgroundColor="{StaticResource PrimaryLight}"
                               StrokeShape="RoundRectangle 12"
                               StrokeThickness="0"
                               Padding="0"
                               HeightRequest="64"
                               WidthRequest="64">
                            <Label Text="📡" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="{Binding Device.Name}" 
                                   FontSize="18"
                                   FontFamily="PoppinsBold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding Device.DeviceTypeName}" 
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding Device.CompanyName}" 
                                   FontSize="12"
                                   TextColor="{StaticResource Primary}" />
                        </VerticalStackLayout>

                        <!-- Battery Badge -->
                        <Border Grid.Column="2" 
                                BackgroundColor="{StaticResource SurfaceLight}" 
                                StrokeShape="RoundRectangle 8" 
                                Padding="8,4"
                                VerticalOptions="Start">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="🔋" FontSize="12" />
                                <Label Text="{Binding Device.BatteryDisplay}"
                                       FontSize="12"
                                       FontFamily="PoppinsBold"
                                       TextColor="{Binding Device.BatteryColor}" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- Quick Actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="📊 Voir Graphique"
                            Command="{Binding ViewChartCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HeightRequest="48"
                            FontSize="13" />
                    <Button Grid.Column="1"
                            Text="🏠 Dashboard"
                            Command="{Binding NavigateToDashboardCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="48"
                            FontSize="13" />
                </Grid>

            <!-- Configuration Section -->
            <Label Text="Configuration" Style="{StaticResource SectionTitle}" />

            <Border Style="{StaticResource CardView}" Padding="16">
                <VerticalStackLayout Spacing="16">
                    
                    <!-- Name -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nom" Style="{StaticResource CardSubtitle}" />
                        <Entry Text="{Binding Name}" Placeholder="Nom du kapteur" Style="{StaticResource ModernEntry}" />
                    </VerticalStackLayout>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Description" Style="{StaticResource CardSubtitle}" />
                        <Editor Text="{Binding Description}" 
                                Placeholder="Description"
                                HeightRequest="80"
                                AutoSize="TextChanges"
                                Style="{StaticResource ModernEditor}" />
                    </VerticalStackLayout>

                    <!-- Installation Location -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Emplacement" Style="{StaticResource CardSubtitle}" />
                        <Entry Text="{Binding InstallationLocation}" Placeholder="Emplacement d'installation" Style="{StaticResource ModernEntry}" />
                    </VerticalStackLayout>

                    <!-- Active Toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" 
                               Text="Actif dans KropKontrol" 
                               VerticalOptions="Center"
                               Style="{StaticResource CardTitle}"
                               FontSize="14" />
                        <Switch Grid.Column="1" 
                                IsToggled="{Binding IsActive}"
                                OnColor="{StaticResource Primary}"
                                ThumbColor="{StaticResource White}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Error Message -->
            <Border IsVisible="{Binding HasError}" 
                   BackgroundColor="#33FF1744"
                   Stroke="{StaticResource Error}"
                   StrokeShape="RoundRectangle 8"
                   Padding="12">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" FontSize="14" />
            </Border>

            <!-- Save Button -->
            <Button 
                Text="Enregistrer"
                Command="{Binding SaveChangesCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                Style="{StaticResource PrimaryButton}"
                HeightRequest="50" />

            <!-- Device Info -->
            <Label Text="Informations" Style="{StaticResource SectionTitle}" />

            <Border Style="{StaticResource CardView}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,*">
                        <Label Grid.Column="0" Text="DevEUI" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                        <Label Grid.Column="1" Text="{Binding Device.DevEui}" TextColor="{StaticResource TextPrimary}" FontSize="12" HorizontalOptions="End" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource SurfaceLight}" />
                    
                    <Grid ColumnDefinitions="*,*">
                        <Label Grid.Column="0" Text="Entreprise" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                        <Label Grid.Column="1" Text="{Binding Device.CompanyName}" TextColor="{StaticResource TextPrimary}" FontSize="12" HorizontalOptions="End" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource SurfaceLight}" />
                    
                    <Grid ColumnDefinitions="*,*">
                        <Label Grid.Column="0" Text="Dernière transmission" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                        <Label Grid.Column="1" Text="{Binding Device.LastSendAt}" TextColor="{StaticResource TextPrimary}" FontSize="12" HorizontalOptions="End" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*">
                        <Label Grid.Column="0" Text="Heure locale" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                        <Label Grid.Column="1" Text="{Binding Device.LastTransmissionLocal}" TextColor="{StaticResource TextPrimary}" FontSize="12" HorizontalOptions="End" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
