<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Kk.Kharts.Maui.ViewModels"
             xmlns:models="clr-namespace:Kk.Kharts.Maui.Models"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:behaviors="clr-namespace:Kk.Kharts.Maui.Behaviors"
             x:Class="Kk.Kharts.Maui.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
       
             Background="{StaticResource DashboardBackgroundBrush}">

    <Grid RowDefinitions="Auto,*">
        <!-- Gradient Header Background -->
        <BoxView Grid.Row="0" HeightRequest="180" VerticalOptions="Start">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#29CF8F" Offset="0" />
                    <GradientStop Color="#1A9F7A" Offset="0.6" />
                    <GradientStop Color="#108A6B" Offset="1" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <RefreshView Grid.RowSpan="2"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}"
                     RefreshColor="{StaticResource White}">
            
            <CollectionView ItemsSource="{Binding DisplayGroups}"
                            IsGrouped="True"
                            SelectionMode="None">
                <CollectionView.Behaviors>
                    <behaviors:MouseWheelScrollBehavior />
                </CollectionView.Behaviors>

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="20" Padding="16,12,16,24">
                        <!-- Welcome -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20" Padding="8,8,8,0" VerticalOptions="Center">
                            <VerticalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                <Label Text="KropKontrol"
                                       FontSize="30"
                                       FontFamily="PoppinsBold"
                                       TextColor="White" />
                                <Label Text="Tableau de bord IoT"
                                       FontSize="14"
                                       TextColor="#F0FFFA"
                                       Opacity="0.9" />
                            </VerticalStackLayout>

                            <Grid Grid.Column="1" WidthRequest="120" HeightRequest="120" HorizontalOptions="End" VerticalOptions="Center">
                                <Border WidthRequest="96"
                                        HeightRequest="96"
                                        Background="{StaticResource HeroIconBrush}"
                                        StrokeShape="Ellipse"
                                        Padding="0"
                                        Opacity="0.85">
                                    <Grid>
                                        <Label Text="K"
                                               FontFamily="PoppinsExtraBold"
                                               FontSize="36"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               TranslationX="-8" />
                                        <Label Text="K"
                                               FontFamily="PoppinsExtraBold"
                                               FontSize="36"
                                               TextColor="#CFFFEA"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               TranslationX="8">
                                            <Label.ScaleX>
                                                -1
                                            </Label.ScaleX>
                                        </Label>
                                    </Grid>
                                </Border>
                                <Border WidthRequest="120"
                                        HeightRequest="120"
                                        StrokeShape="Ellipse"
                                        Stroke="White"
                                        StrokeThickness="2"
                                        Opacity="0.25" />
                            </Grid>
                        </Grid>

                        <!-- Stats -->
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                            <Border Style="{StaticResource CardView}" Padding="12" BackgroundColor="{StaticResource Surface}">
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="{Binding TotalDevices}" FontSize="28" FontFamily="PoppinsBold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                                    <Label Text="Kapteurs" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardView}" Padding="12" BackgroundColor="{StaticResource Surface}">
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="{Binding ActiveDevices}" FontSize="28" FontFamily="PoppinsBold" TextColor="{StaticResource Success}" HorizontalOptions="Center" />
                                    <Label Text="Actifs" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardView}" Padding="12" BackgroundColor="{StaticResource Surface}">
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="{Binding TotalCompanies}" FontSize="28" FontFamily="PoppinsBold" TextColor="{StaticResource Secondary}" HorizontalOptions="Center" />
                                    <Label Text="Sites" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource CardView}" Padding="12" BackgroundColor="{StaticResource Surface}">
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="{Binding LowBatteryDevices}" FontSize="28" FontFamily="PoppinsBold" TextColor="{StaticResource Warning}" HorizontalOptions="Center" />
                                    <Label Text="Alertes" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Search -->
                        <Border Style="{StaticResource CardView}" BackgroundColor="{StaticResource Surface}" Padding="4,4,12,4">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="🔍" FontSize="18" VerticalOptions="Center" Margin="12,0,8,0" />
                                <Entry Grid.Column="1"
                                       Placeholder="Rechercher un kapteur, site..."
                                       Text="{Binding SearchQuery}"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!-- Section Header -->
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Text="Mes Kapteurs" Style="{StaticResource SectionTitle}" />
                            <Button Text="{Binding ShowGroupedView, Converter={StaticResource BoolToViewModeConverter}}"
                                    Command="{Binding ToggleViewCommand}"
                                    Style="{StaticResource GhostButton}"
                                    Grid.Column="1"
                                    FontSize="12"
                                    HeightRequest="32" />
                        </Grid>

                        <!-- Error Banner -->
                        <Border IsVisible="{Binding HasError}"
                               BackgroundColor="#20C62828"
                               Stroke="{StaticResource Error}"
                               StrokeShape="RoundRectangle 8"
                               Padding="12">
                            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" FontSize="14" />
                        </Border>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:CompanyGroup">
                        <VerticalStackLayout Padding="16,8,16,8" 
                                             IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=ShowGroupedView}">
                            <Border BackgroundColor="{StaticResource PrimaryLight}" StrokeShape="RoundRectangle 8" Padding="12,8">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Text="{Binding CompanyName}" FontSize="14" FontFamily="PoppinsSemiBold" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center" />
                                    <Border Grid.Column="1" BackgroundColor="{StaticResource Primary}" StrokeShape="RoundRectangle 10" Padding="8,2" HorizontalOptions="End">
                                        <Label Text="{Binding DeviceCount}" FontSize="12" FontFamily="PoppinsBold" TextColor="{StaticResource White}" />
                                    </Border>
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=ToggleGroupCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DeviceModel">
                        <VerticalStackLayout Padding="16,0,16,8">
                            <Border Style="{StaticResource CardView}" Padding="12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=SelectDeviceCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceLight}" StrokeShape="RoundRectangle 10" HeightRequest="44" WidthRequest="44">
                                        <Label Text="📡" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}" FontSize="14" FontFamily="PoppinsSemiBold" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" />
                                        <Label FontSize="12" TextColor="{StaticResource TextSecondary}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding CompanyName}" />
                                                    <Span Text=" • " />
                                                    <Span Text="{Binding DeviceTypeName}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                        <Border BackgroundColor="{StaticResource SurfaceLight}" StrokeShape="RoundRectangle 8" Padding="6,3">
                                            <Label Text="{Binding BatteryDisplay}" FontSize="11" FontFamily="PoppinsBold" TextColor="{Binding BatteryColor}" />
                                        </Border>
                                        <Label Text="📊" FontSize="20" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="40" Spacing="16">
                        <Label Text="🔍" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="Aucun kapteur trouvé" FontSize="16" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                        <Button Text="Actualiser" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" WidthRequest="150" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
