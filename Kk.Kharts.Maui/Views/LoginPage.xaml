<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Kk.Kharts.Maui.ViewModels"
             x:Class="Kk.Kharts.Maui.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource White}">

    <Grid>
        <!-- Background Gradient -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#121212" Offset="0.0" />
                    <GradientStop Color="#1E1E1E" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Decorative Circles -->
        <Ellipse WidthRequest="300" HeightRequest="300" Fill="{StaticResource Primary}" Opacity="0.1"
                 HorizontalOptions="Start" VerticalOptions="Start" Margin="-100,-100,0,0" />
        <Ellipse WidthRequest="200" HeightRequest="200" Fill="{StaticResource Secondary}" Opacity="0.1"
                 HorizontalOptions="End" VerticalOptions="End" Margin="0,0,-50,-50" />

        <Grid RowDefinitions="*,Auto" Padding="20">
            <!-- Main Content -->
            <VerticalStackLayout 
                Grid.Row="0"
                VerticalOptions="Center"
                Spacing="30">

                <!-- Logo and Title -->
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Image 
                        Source="logo.png"
                        HeightRequest="100"
                        WidthRequest="100"
                        HorizontalOptions="Center" />
                    
                    <Label 
                        Text="KropKontrol"
                        FontSize="36"
                        FontFamily="PoppinsBold"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalOptions="Center" />
                    
                    <Label 
                        Text="L'intelligence au service de vos cultures"
                        FontSize="16"
                        FontFamily="PoppinsRegular"
                        TextColor="{StaticResource TextSecondary}"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Login Form -->
                <Border 
                    Style="{StaticResource GlassCard}"
                    Margin="0,20,0,0">
                    
                    <VerticalStackLayout Spacing="20">
                        <!-- Email -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email" FontFamily="PoppinsSemiBold" TextColor="{StaticResource TextPrimary}" />
                            <Entry 
                                Text="{Binding Email}"
                                Placeholder="votre@email.com"
                                Style="{StaticResource ModernEntry}"
                                Keyboard="Email"
                                ReturnType="Next" />
                            <BoxView HeightRequest="1" Color="{StaticResource TextSecondary}" Opacity="0.5" />
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Mot de passe" FontFamily="PoppinsSemiBold" TextColor="{StaticResource TextPrimary}" />
                            <Entry 
                                Text="{Binding Password}"
                                Placeholder="••••••••"
                                Style="{StaticResource ModernEntry}"
                                IsPassword="True"
                                ReturnType="Done"
                                ReturnCommand="{Binding LoginCommand}" />
                            <BoxView HeightRequest="1" Color="{StaticResource TextSecondary}" Opacity="0.5" />
                        </VerticalStackLayout>

                        <!-- Error Message -->
                        <Label 
                            Text="{Binding ErrorMessage}"
                            TextColor="{StaticResource Error}"
                            FontSize="12"
                            IsVisible="{Binding HasError}"
                            HorizontalOptions="Center" />

                        <!-- Login Button -->
                        <Button 
                            Text="{Binding IsBusy, Converter={StaticResource BoolToLoginTextConverter}}"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Footer -->
            <VerticalStackLayout 
                Grid.Row="1"
                Spacing="4"
                HorizontalOptions="Center"
                Margin="0,0,0,20">
                
                <Label 
                    FontSize="12"
                    TextColor="{StaticResource TextSecondary}"
                    HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="KropKontrol par " />
                            <Span Text="3ctec" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                            <Span Text=" et " />
                            <Span Text="StratBerries" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                
                <Label 
                    Text="info@kropkontrol.com"
                    FontSize="11"
                    TextColor="{StaticResource TextDisabled}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
