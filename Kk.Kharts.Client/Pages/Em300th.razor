    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(DevEui))
        {
            return;
        }

        IsLoading = true;

        try
        {
            string url = $"https://localhost:7083/api/Em300Th/DeviceByDevEui?DevEui={DevEui}&StartDate={StartDate:yyyy-MM-ddTHH:mm:ss}&EndDate={EndDate:yyyy-MM-ddTHH:mm:ss}";
            Data = await Http.GetFromJsonAsync<List<Em300Th>>(url) ?? new List<Em300Th>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar os dados: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged(); // FORÇAR ATUALIZAÇÃO DA UI
        }
    }




    private void OnStartDateChanged(DateTime? date)
    {
        if (date.HasValue)
            StartDate = date.Value;
    }


    private void OnEndDateChanged(DateTime? date)
    {
        if (date.HasValue)
            EndDate = date.Value;
    }


    protected override async Task OnInitializedAsync()
    {
        // Chama a API para obter os dispositivos
        Devices = await Http.GetFromJsonAsync<List<Device>>("api/device/name");

        await LoadData();
        Console.WriteLine($"Dados carregados: {Data.Count} registros");
        foreach (var item in Data)
        {
            Console.WriteLine($"Timestamp: {item.Timestamp}, Temp: {item.Temperature}");
        }
    }


}
