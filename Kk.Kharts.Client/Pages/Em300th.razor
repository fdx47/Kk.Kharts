@page "/em300th"
@using ApexCharts
@using Kk.Kharts.Shared.Entities
@using Kk.Kharts.Shared.Entities.Em300
@using MudBlazor
@inject HttpClient Http

<MudCard Class="pa-4">
    <MudCardHeader>
        <MudText Typo="Typo.h5">Gráfico de Temperatura do Sensor EM300-TH</MudText>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect Label="Nom du capteur" @bind-Value="DevEui" T="string">
                    @foreach (var device in Devices)
                    {
                        <MudSelectItem Value="@device.DevEui">@device.DevEui</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudTextField Label="Device EUI" @bind-Value="DevEui" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="Data Início" Date="@StartDate" DateChanged="OnStartDateChanged" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="Data Fim" Date="@EndDate" DateChanged="OnEndDateChanged" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Color="MudBlazor.Color.Primary" OnClick="LoadData" StartIcon="@Icons.Material.Filled.Search">Buscar</MudButton>
            </MudItem>
        </MudGrid>

        <MudProgressLinear Indeterminate="true" Color="MudBlazor.Color.Primary" Style="margin-top:10px;" Visible="IsLoading" />

        @code {

        }

        @if (Data == null || !Data.Any())
        {
            <MudAlert Severity="Severity.Warning">Nenhum dado encontrado.</MudAlert>
        }
        else
        {
            <MudCardHeader>
                <MudText Typo="Typo.h5">
                    @* Temperatura - @Data.FirstOrDefault()?.DeviceName *@
                </MudText>
            </MudCardHeader>

            <ApexChart TItem="Em300Th" Title="Dados do Sensor" Height="600">
                <ApexPointSeries TItem="Em300Th"
                                 Items="Data"
                                 Name="@chartTitle"
                                 SeriesType="SeriesType.Line"
                                 XValue="e => e.Timestamp"
                                 YValue="e => (decimal)e.Temperature" />
            </ApexChart>
        }

    </MudCardContent>
</MudCard>

@code {

