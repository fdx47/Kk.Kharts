}

@code {
    private List<SensorData> SensorDataList { get; set; } = new();
    private bool isLoading = true;
    private string? errorMessage;
    private readonly string devEui = "24E124454E048465";
    private readonly string startDate = DateTime.Now.AddDays(-7).ToString("yyyy-MM-ddTHH:mm:ss");
    private readonly string endDate = DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            SensorDataList = await GetSensorDataAsync(devEui, startDate, endDate);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<List<SensorData>> GetSensorDataAsync(string devEui, string startDate, string endDate)
    {
        try
        {
            var url = $"api/v1/Uc502Wet150/GetByDevEui?devEui={devEui}" +
                     $"&startDate={Uri.EscapeDataString(startDate)}" +
                     $"&endDate={Uri.EscapeDataString(endDate)}";
            
            var response = await Http.GetFromJsonAsync<SensorDataResponse>(url);
            return response?.Data?.OrderBy(x => x.Timestamp).ToList() ?? new List<SensorData>();
        }
        catch
        {
            return new List<SensorData>();
        }
    }

    public class SensorData
    {
        public DateTime Timestamp { get; set; }
        public double SoilTemperature { get; set; }
        public double ECb { get; set; }
    }

    public class SensorDataResponse
    {
        public List<SensorData> Data { get; set; } = new();
    }
}