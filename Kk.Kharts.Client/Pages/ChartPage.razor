@code {


    private List<SensorData> Orders { get; set; } = new();

    private async Task LoadDataFromApi()
    {
        string devEui = "24E124454E048465";
        string startDate = "2025-04-06 10:45:13";
        string endDate = "2025-04-11 10:45:13";

        // Chamada à API
        var sensorData = await ApiService.GetSensorDataAsync(devEui, startDate, endDate);

        // Verifica se há dados
        if (sensorData == null || !sensorData.Any())
        {
            Console.WriteLine("Aucune donnée reçue.");
            return;
        }

        Console.WriteLine($"Nombre d'enregistrements reçus : {sensorData.Count}");

        // Mapeia os dados para uma lista de Order (exemplo de estrutura abaixo)
        Orders = sensorData.Select(d => new SensorData
            {
                Timestamp = d.Timestamp,
                CoirVWC = d.CoirVWC,
                SoilTemperature = d.SoilTemperature,
                Battery = d.Battery
            }).ToList();

        // Apenas para debug
        foreach (var order in Orders)
        {
            // Console.WriteLine($"Order: {order.Timestamp}, CoirVWC: {order.CoirVWC}, Temp: {order.Temperature}, Battery: {order.Battery}");
        }

        StateHasChanged(); // Atualiza o UI
    }
}